# Copy to .env.local and adjust as needed

# ── API target ──────────────────────────────────────────────
# For local backend (set AUTH_COOKIE_DOMAIN="" on backend):
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/v1/legacy
# For deployed staging:
NEXT_PUBLIC_API_BASE_URL=https://api.lawbrokr.ca/v1/legacy

# ── Token refresh ──────────────────────────────────────────
# Seconds before token expiry to trigger auto-refresh (default: 30)
# NEXT_PUBLIC_REFRESH_BUFFER_SECONDS=30

# ── Session expiry ─────────────────────────────────────────
# Days before the session cookie expires and forces re-login (default: 1)
# For production, set to 30
# NEXT_PUBLIC_SESSION_EXPIRY_DAYS=1
