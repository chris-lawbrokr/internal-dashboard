# Copy to .env.local and adjust as needed

# ── API target ──────────────────────────────────────────────
# For local backend (set AUTH_COOKIE_DOMAIN="" on backend):
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/v1/legacy
# For deployed staging:
NEXT_PUBLIC_API_BASE_URL=https://api.lawbrokr.ca/v1/legacy

# ── Token refresh ──────────────────────────────────────────
# Seconds before token expiry to trigger auto-refresh (default: 60)
# NEXT_PUBLIC_REFRESH_BUFFER_SECONDS=60
